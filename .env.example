# Production URL (used in emails and links)
NEXT_PUBLIC_APP_URL=https://familyphotohunt.com

# Database — path is relative to prisma/schema.prisma (NOT the project root).
# file:../data/dev.db → data/dev.db on disk → /app/data/dev.db on Railway volume
DATABASE_URL="file:../data/dev.db"

# Email (for send-email API; optional)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your@gmail.com
# EMAIL_PASSWORD=your-app-password

# Site owner console (super admin) — separate from participant/organizer login
# Set these in Railway Variables; never commit real values.
# SUPER_ADMIN_USERNAME=siteowner
# SUPER_ADMIN_PASSWORD=your-strong-password
# SUPER_ADMIN_SESSION_SECRET=long-random-string-at-least-32-characters
